<%- include('partials/header') %>

<div class="page-wrapper form-page">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">

        <a href="/" class="back-link mb-4 d-inline-flex align-items-center">
          <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>

        <div class="form-card">

          <div class="form-card-header">
            <h2 class="form-card-title">Add New Task</h2>
          </div>

          <% if (error) { %>
          <div class="alert alert-danger custom-alert alert-dismissible fade show mx-4" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <% } %>

          <!-- Form -->
          <div class="form-card-body">
            <form action="/task/add" method="POST" novalidate>

              <div class="mb-4">
                <label class="form-label-custom" for="title">
                  Task Title <span class="req">*</span>
                </label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  class="form-control form-control-custom"
                  placeholder="e.g. Prepare Monthly Report"
                  maxlength="100"
                  required
                />
              </div>

              <div class="mb-4">
                <label class="form-label-custom" for="description">
                  Description
                </label>
                <textarea
                  id="description"
                  name="description"
                  class="form-control form-control-custom"
                  rows="3"
                  placeholder="Optional — describe what this task involves..."
                  maxlength="300"
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label-custom" for="priority">
                  Priority
                </label>
                <select id="priority" name="priority" class="form-select form-control-custom">
                  <option value="Low">Low</option>
                  <option value="Medium" selected>Medium</option>
                  <option value="High">High</option>
                </select>
              </div>

              <div class="form-hint mb-4">
                <i class="bi bi-info-circle me-1"></i>
                New tasks start with <strong>Pending</strong> status by default.
              </div>

              <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary-custom flex-fill">
                  <i class="bi bi-plus-lg me-2"></i>Add Task
                </button>
                <a href="/" class="btn btn-secondary-custom">
                  Cancel
                </a>
              </div>

            </form>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
