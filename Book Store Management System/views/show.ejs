<%- include("partials/header") %>

<div class="wrapper">
  <div class="show-wrap">
    <a href="/" class="back">Back to Books</a>

    <div class="show-card">
      <div class="show-img-col">
        <% if (book.image) { %>
          <img src="/uploads/<%= book.image %>" alt="<%= book.title %>"/>
        <% } else { %>
          <div class="no-img-lg">No Image</div>
        <% } %>
      </div>

      <div class="show-info-col">
        <span class="show-cat"><%= book.category %></span>
        <h1 class="show-title"><%= book.title %></h1>
        <p class="show-author">by <strong><%= book.author %></strong></p>

        <div class="show-meta">
          <div class="meta-item">
            <div class="lbl">Price</div>
            <div class="val price">Rs. <%= book.price %></div>
          </div>
          <div class="meta-item">
            <div class="lbl">Quantity</div>
            <div class="val"><%= book.quantity %> units</div>
          </div>
          <div class="meta-item">
            <div class="lbl">Total Value</div>
            <div class="val">Rs. <%= book.price * book.quantity %></div>
          </div>
          <div class="meta-item">
            <div class="lbl">Category</div>
            <div class="val"><%= book.category %></div>
          </div>
        </div>

        <% if (book.description) { %>
          <div class="show-desc">
            <h3>About this Book</h3>
            <p><%= book.description %></p>
          </div>
        <% } %>

        <div class="show-actions">
          <a href="/edit/<%= book._id %>" class="btn btn-primary">Edit</a>
          <a href="/delete/<%= book._id %>" class="btn btn-danger"
             onclick="return confirm('Delete this book?')">Delete</a>
          <a href="/" class="btn btn-ghost">Back</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>