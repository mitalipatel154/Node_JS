<%- include("partials/header") %>

<div class="wrapper">
  <div class="form-wrap">
    <a href="/" class="back">Back to Books</a>
    <h2>Add New Book</h2>

    <div class="form-card">
      <form action="/add" method="POST" enctype="multipart/form-data" id="bookForm">
        <div class="form-body">

          <div class="field full">
            <label>Book Cover Image</label>
            <div class="file-upload-box" id="uploadBox">
              <input type="file" name="image" id="imageInput" accept="image/*"/>
              <div class="file-upload-inner" id="uploadInner">
                <p>Click or drag to upload cover</p>
                <span>JPEG, PNG, GIF · Max 5MB</span>
              </div>
              <img id="imgPreview" src="" alt="Preview"/>
            </div>
          </div>

          <div class="form-row">
            <div class="field full">
              <label>Book Title *</label>
              <input type="text" name="title" placeholder="e.g. Rich Dad Poor Dad" required/>
            </div>
            <div class="field">
              <label>Author *</label>
              <input type="text" name="author" placeholder="e.g. Robert Kiyosaki" required/>
            </div>
            <div class="field">
              <label>Category *</label>
              <select name="category" required>
                <option value="">Select category</option>
                <option>Fiction</option>
                <option>Non-Fiction</option>
                <option>Science</option>
                <option>Technology</option>
                <option>Finance</option>
                <option>History</option>
                <option>Biography</option>
                <option>Self-Help</option>
                <option>Children</option>
                <option>Romance</option>
                <option>Mystery</option>
                <option>Philosophy</option>
                <option>Other</option>
              </select>
            </div>
            <div class="field">
              <label>Price (Rs.) *</label>
              <input type="number" name="price" placeholder="499" min="0" required/>
            </div>
            <div class="field">
              <label>Quantity *</label>
              <input type="number" name="quantity" placeholder="10" min="0" required/>
            </div>
            <div class="field full">
              <label>Description</label>
              <textarea name="description" placeholder="Brief description of the book..."></textarea>
            </div>
          </div>

        </div>
        <div class="form-footer">
          <a href="/" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary" id="submitBtn">Add Book</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include("partials/footer") %>